# Server-only — never prefix with NEXT_PUBLIC_
YOUTUBE_API_KEY=your_youtube_data_api_key_here

# Canonical site origin (SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://flamekyro.com

# Optional in development — required in production (Vercel).
# Durable visitor counters via Upstash Redis REST (unique + total visits).
# Without these locally, counts use `.data/visitors.json` (dev only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
